{
  "name": "upcommander",
  "displayName": "UpCommander by UpGPT",
  "description": "UpCommander by UpGPT — multi-model agent orchestration for developers",
  "version": "1.0.0",
  "publisher": "upgpt",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "upcommander",
          "title": "UpCommander",
          "icon": "$(arrow-up)"
        }
      ]
    },
    "views": {
      "upcommander": [
        {
          "id": "upcommander-sessions",
          "name": "Sessions",
          "icon": "$(terminal-tmux)",
          "contextualTitle": "UpCommander Sessions"
        },
        {
          "id": "upcommander-approvals",
          "name": "Approval Queue",
          "icon": "$(bell)",
          "contextualTitle": "UpCommander Approvals"
        }
      ]
    },
    "commands": [
      {
        "command": "upcommander.connect",
        "title": "Connect to Bridge",
        "category": "UpCommander",
        "icon": "$(plug)"
      },
      {
        "command": "upcommander.disconnect",
        "title": "Disconnect",
        "category": "UpCommander",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "upcommander.sendPrompt",
        "title": "Send Prompt to Session",
        "category": "UpCommander",
        "icon": "$(send)"
      },
      {
        "command": "upcommander.approve",
        "title": "Approve Action",
        "category": "UpCommander",
        "icon": "$(check)"
      },
      {
        "command": "upcommander.deny",
        "title": "Deny Action",
        "category": "UpCommander",
        "icon": "$(x)"
      },
      {
        "command": "upcommander.broadcast",
        "title": "Broadcast to Session",
        "category": "UpCommander",
        "icon": "$(radio-tower)"
      },
      {
        "command": "upcommander.broadcastAll",
        "title": "Broadcast to All",
        "category": "UpCommander",
        "icon": "$(broadcast)"
      },
      {
        "command": "upcommander.refresh",
        "title": "Refresh Sessions",
        "category": "UpCommander",
        "icon": "$(refresh)"
      },
      {
        "command": "upcommander.openFile",
        "title": "Open File",
        "category": "UpCommander",
        "icon": "$(go-to-file)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "upcommander.refresh",
          "when": "view == upcommander-sessions",
          "group": "navigation"
        },
        {
          "command": "upcommander.broadcastAll",
          "when": "view == upcommander-sessions",
          "group": "navigation"
        },
        {
          "command": "upcommander.connect",
          "when": "view == upcommander-sessions && !upcommander.connected",
          "group": "navigation"
        },
        {
          "command": "upcommander.disconnect",
          "when": "view == upcommander-sessions && upcommander.connected",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "upcommander.sendPrompt",
          "when": "view == upcommander-sessions && viewItem == window",
          "group": "inline"
        },
        {
          "command": "upcommander.broadcast",
          "when": "view == upcommander-sessions && viewItem == session",
          "group": "inline"
        },
        {
          "command": "upcommander.approve",
          "when": "view == upcommander-approvals && viewItem == approval",
          "group": "inline"
        },
        {
          "command": "upcommander.deny",
          "when": "view == upcommander-approvals && viewItem == approval",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Commander",
      "properties": {
        "upcommander.bridgeUrl": {
          "type": "string",
          "default": "http://127.0.0.1:7700",
          "description": "URL of the Commander bridge server"
        },
        "upcommander.token": {
          "type": "string",
          "default": "",
          "description": "Bearer token for authenticating with the bridge server",
          "markdownDescription": "Bearer token. Find this in `~/.upcommander/token` or from the bridge server's startup log."
        },
        "upcommander.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to the bridge server on startup"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
