  "leaf_element": {
    "description": "A leaf element references a single file in the submission",
    "content_model": "(title, link-text?)",
    "attributes": {
      "ID": { "type": "ID", "required": true, "description": "Unique identifier for this leaf in the XML instance. Starts with alphabetic char or underscore." },
      "operation": { "type": "enum", "values": ["new", "append", "replace", "delete"], "required": true },
      "checksum": { "type": "CDATA", "required": true, "description": "MD5 hash of the referenced file" },
      "checksum-type": { "type": "CDATA", "required": true, "description": "Always 'md5'" },
      "xlink:href": { "type": "CDATA", "required": false, "description": "Relative path to the content file" },
      "xlink:type": { "type": "CDATA", "fixed": "simple" },
      "modified-file": { "type": "CDATA", "required": false, "description": "Points to leaf being modified: ../NNNN/index.xml#leafID" },
      "application-version": { "type": "CDATA", "required": false, "description": "File format version, e.g., 'PDF 1.4'" },
      "version": { "type": "CDATA", "required": false, "description": "Submitter's internal version number" },
      "xml:lang": { "type": "CDATA", "required": false, "description": "ISO-639 language code" },
      "keywords": { "type": "CDATA", "required": false },
      "font-library": { "type": "CDATA", "required": false, "description": "Reserved for future use" },
      "xlink:role": { "type": "CDATA", "required": false, "description": "Reserved for future use" },
      "xlink:show": { "type": "enum", "values": ["new", "replace", "embed", "other", "none"], "required": false },
      "xlink:actuate": { "type": "enum", "values": ["onLoad", "onRequest", "other", "none"], "required": false },
      "xmlns:xlink": { "type": "CDATA", "fixed": "http://www.w3.org/1999/xlink" }
    }
  },
  "node_extension": {
    "description": "Allows extending the eCTD DTD hierarchy at the lowest defined level",
    "content_model": "(title, (leaf | node-extension)+)",
    "attributes": {
      "ID": { "type": "ID", "required": false },
      "xml:lang": { "type": "CDATA", "required": false }
    },
    "rules": [
      "Only extend at the lowest level of defined table-of-contents elements",
      "Title element is inherited from parent",
      "Use is discouraged and should be unavoidable",
      "Consult regional guidance before using"
    ]
  },
  "accepted_file_formats": {
    "documents": {
      "pdf": { "preferred": true, "version": "1.4", "max_size_mb": 100, "notes": "Optimized for fast web view, no security/passwords" },
      "rtf": { "preferred": false },
      "xml": { "preferred": false, "notes": "For structured data only" }
    },
    "images": {
      "jpeg": { "preferred": true },
      "png": { "preferred": true },
      "svg": { "preferred": false, "notes": "Discuss with regulatory authority" },
      "gif": { "preferred": false }
    },
    "data": {
      "xls": { "preferred": false },
      "xpt": { "preferred": false, "notes": "SAS transport format" }
    }
  },
  "pdf_requirements": {
    "version": "1.4",
    "fonts": "Embed all non-standard fonts (Times New Roman, Arial, Courier are standard)",
    "font_size": "12pt minimum for narrative, 9-10pt acceptable for tables",
    "color": "Black recommended, blue for hyperlinks",
    "margins": "2.5cm left minimum for portrait",
    "page_size": "A4 (210x297mm) or Letter (8.5x11 inches)",
    "bookmarks": "Required for documents with table of contents, max 4 levels deep",
    "hyperlinks": "Relative paths only, use blue text or thin rectangles",
    "page_numbering": "Arabic numerals starting at 1, consecutive throughout",
    "security": "No password protection, no security restrictions",
    "scanning_dpi": "300 for documents, 600 for photographs and non-Western characters",
    "compression": "Zip/Flate for color/grayscale, CCITT Group 4 for B&W"
  }
}
