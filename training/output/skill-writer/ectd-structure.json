                "substance": { "type": "CDATA", "required": true },
                "manufacturer": { "type": "CDATA", "required": true }
              },
              "content_model": "(leaf*, m3-2-s-1-general-information?, m3-2-s-2-manufacture?, m3-2-s-3-characterisation?, m3-2-s-4-control-of-drug-substance?, m3-2-s-5-reference-standards-or-materials?, m3-2-s-6-container-closure-system?, m3-2-s-7-stability?)",
              "children": {
                "m3-2-s-1-general-information": {
                  "ctd_section": "3.2.S.1",
                  "xml_element": "m3-2-s-1-general-information",
                  "content_model": "(leaf*, m3-2-s-1-1-nomenclature?, m3-2-s-1-2-structure?, m3-2-s-1-3-general-properties?)",
                  "children": {
                    "m3-2-s-1-1-nomenclature": { "ctd_section": "3.2.S.1.1", "content_model": "((leaf | node-extension)*)" },
                    "m3-2-s-1-2-structure": { "ctd_section": "3.2.S.1.2", "content_model": "((leaf | node-extension)*)" },
                    "m3-2-s-1-3-general-properties": { "ctd_section": "3.2.S.1.3", "content_model": "((leaf | node-extension)*)" }
                  }
                },
                "m3-2-s-2-manufacture": {
                  "ctd_section": "3.2.S.2",
                  "xml_element": "m3-2-s-2-manufacture",
