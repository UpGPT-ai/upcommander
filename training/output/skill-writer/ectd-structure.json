                  "children": {
                    "m3-2-p-4-1-specifications": { "ctd_section": "3.2.P.4.1", "content_model": "((leaf | node-extension)*)" },
                    "m3-2-p-4-2-analytical-procedures": { "ctd_section": "3.2.P.4.2", "content_model": "((leaf | node-extension)*)" },
                    "m3-2-p-4-3-validation-of-analytical-procedures": { "ctd_section": "3.2.P.4.3", "content_model": "((leaf | node-extension)*)" },
                    "m3-2-p-4-4-justification-of-specifications": { "ctd_section": "3.2.P.4.4", "content_model": "((leaf | node-extension)*)" },
                    "m3-2-p-4-5-excipients-of-human-or-animal-origin": { "ctd_section": "3.2.P.4.5", "content_model": "((leaf | node-extension)*)" },
