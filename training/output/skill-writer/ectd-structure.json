{
  "meta": {
    "specification": "eCTD v3.2.2",
    "source": "ICH M2 EWG, July 2008",
    "dtd_version": "3.2",
    "namespace": "http://www.ich.org/ectd"
  },
  "file_naming_rules": {
    "allowed_characters": "a-z (lowercase), 0-9, hyphen (-)",
    "max_filename_length": 64,
    "max_path_length": 230,
    "extension": "single extension only (e.g., .pdf not .backup.pdf)",
    "case": "lowercase only",
    "no_spaces": true,
    "no_special_characters": true
  },
  "submission_structure": {
    "root": "ctd-{dossier-number}/",
    "description": "Top-level dossier folder using applicant/regulator assigned number",
    "sequences": {
      "pattern": "{NNNN}/",
      "initial": "0000",
      "subsequent": "0001, 0002, ..., 9999",
      "description": "Each submission sequence is a 4-digit zero-padded number"
    },
    "sequence_contents": {
      "index.xml": {
        "required": true,
        "description": "XML backbone referencing all files in this sequence"
      },
      "index-md5.txt": {
        "required": true,
        "description": "MD5 checksum of index.xml file"
      },
      "m1/": { "required": "regional", "description": "Module 1 - Regional Administrative Information" },
      "m2/": { "required": false, "description": "Module 2 - Common Technical Document Summaries" },
      "m3/": { "required": false, "description": "Module 3 - Quality" },
      "m4/": { "required": false, "description": "Module 4 - Nonclinical Study Reports" },
      "m5/": { "required": false, "description": "Module 5 - Clinical Study Reports" },
      "util/": { "required": true, "description": "Utility folder for DTDs and stylesheets" }
    }
  },
  "utility_directory": {
    "util/": {
      "dtd/": {
        "ich-ectd-3-2.dtd": { "required": true, "description": "ICH eCTD DTD" },
        "regional DTDs": { "required": "per region", "description": "e.g., us-regional.dtd, eu-regional.dtd" }
      },
      "style/": {
        "ectd-2-0.xsl": { "required": true, "description": "ICH eCTD stylesheet" },
        "regional stylesheets": { "required": "per region", "description": "e.g., us-regional.xsl" }
      }
    }
  },
  "modules": {
    "m1-administrative-information-and-prescribing-information": {
      "ctd_section": "1",
      "xml_element": "m1-administrative-information-and-prescribing-information",
      "directory": "m1/",
      "required": "regional",
      "regional": true,
      "description": "Region-specific administrative and prescribing information",
      "notes": "Structure defined by each regional authority (US, EU, JP, etc.)",
      "children": "Defined by regional DTDs - varies by region",
      "regional_directories": {
        "us": "m1/us/",
        "eu": "m1/eu/",
        "jp": "m1/jp/",
        "xx": "m1/{iso-3166-1-alpha-2}/"
      },
      "content_model": "(leaf*)"
    },
    "m2-common-technical-document-summaries": {
      "ctd_section": "2",
      "xml_element": "m2-common-technical-document-summaries",
      "directory": "m2/",
      "required": false,
      "content_model": "(leaf*, m2-2-introduction?, m2-3-quality-overall-summary?, m2-4-nonclinical-overview?, m2-5-clinical-overview?, m2-6-nonclinical-written-and-tabulated-summaries?, m2-7-clinical-summary?)",
      "children": {
        "m2-2-introduction": {
          "ctd_section": "2.2",
          "xml_element": "m2-2-introduction",
          "directory": "m2/22-intro/",
          "required": false,
          "content_model": "((leaf | node-extension)*)"
        },
        "m2-3-quality-overall-summary": {
          "ctd_section": "2.3",
          "xml_element": "m2-3-quality-overall-summary",
          "directory": "m2/23-qos/",
          "required": false,
          "content_model": "(leaf*, m2-3-introduction?, m2-3-s-drug-substance*, m2-3-p-drug-product*, m2-3-a-appendices?, m2-3-r-regional-information?)",
          "children": {
            "m2-3-introduction": {
              "ctd_section": "2.3.I",
              "xml_element": "m2-3-introduction",
              "directory": "m2/23-qos/",
              "content_model": "((leaf | node-extension)*)"
            },
            "m2-3-s-drug-substance": {
              "ctd_section": "2.3.S",
              "xml_element": "m2-3-s-drug-substance",
              "directory": "m2/23-qos/",
              "content_model": "((leaf | node-extension)*)",
              "attributes": {
                "substance": { "type": "CDATA", "required": true },
                "manufacturer": { "type": "CDATA", "required": true }
              }
            },
            "m2-3-p-drug-product": {
              "ctd_section": "2.3.P",
              "xml_element": "m2-3-p-drug-product",
              "directory": "m2/23-qos/",
              "content_model": "((leaf | node-extension)*)",
              "attributes": {
                "product-name": { "type": "CDATA", "required": false },
                "dosageform": { "type": "CDATA", "required": false },
                "manufacturer": { "type": "CDATA", "required": false }
              }
            },
            "m2-3-a-appendices": {
              "ctd_section": "2.3.A",
              "xml_element": "m2-3-a-appendices",
              "directory": "m2/23-qos/",
              "content_model": "((leaf | node-extension)*)"
            },
            "m2-3-r-regional-information": {
              "ctd_section": "2.3.R",
              "xml_element": "m2-3-r-regional-information",
              "directory": "m2/23-qos/",
              "content_model": "((leaf | node-extension)*)"
            }
          }
        },
        "m2-4-nonclinical-overview": {
          "ctd_section": "2.4",
          "xml_element": "m2-4-nonclinical-overview",
          "directory": "m2/24-nonclin-over/",
          "required": false,
          "content_model": "((leaf | node-extension)*)"
        },
        "m2-5-clinical-overview": {
          "ctd_section": "2.5",
          "xml_element": "m2-5-clinical-overview",
          "directory": "m2/25-clin-over/",
          "required": false,
          "content_model": "((leaf | node-extension)*)"
        },
        "m2-6-nonclinical-written-and-tabulated-summaries": {
          "ctd_section": "2.6",
          "xml_element": "m2-6-nonclinical-written-and-tabulated-summaries",
          "directory": "m2/26-nonclin-sum/",
          "required": false,
          "content_model": "(leaf*, m2-6-1-introduction?, m2-6-2-pharmacology-written-summary?, m2-6-3-pharmacology-tabulated-summary?, m2-6-4-pharmacokinetics-written-summary?, m2-6-5-pharmacokinetics-tabulated-summary?, m2-6-6-toxicology-written-summary?, m2-6-7-toxicology-tabulated-summary?)",
          "children": {
            "m2-6-1-introduction": {
              "ctd_section": "2.6.1",
              "xml_element": "m2-6-1-introduction",
              "content_model": "((leaf | node-extension)*)"
            },
            "m2-6-2-pharmacology-written-summary": {
              "ctd_section": "2.6.2",
              "xml_element": "m2-6-2-pharmacology-written-summary",
              "content_model": "((leaf | node-extension)*)"
            },
            "m2-6-3-pharmacology-tabulated-summary": {
              "ctd_section": "2.6.3",
              "xml_element": "m2-6-3-pharmacology-tabulated-summary",
              "content_model": "((leaf | node-extension)*)"
            },
            "m2-6-4-pharmacokinetics-written-summary": {
              "ctd_section": "2.6.4",
              "xml_element": "m2-6-4-pharmacokinetics-written-summary",
              "content_model": "((leaf | node-extension)*)"
            },
            "m2-6-5-pharmacokinetics-tabulated-summary": {
              "ctd_section": "2.6.5",
              "xml_element": "m2-6-5-pharmacokinetics-tabulated-summary",
              "content_model": "((leaf | node-extension)*)"
            },
            "m2-6-6-toxicology-written-summary": {
              "ctd_section": "2.6.6",
              "xml_element": "m2-6-6-toxicology-written-summary",
              "content_model": "((leaf | node-extension)*)"
            },
            "m2-6-7-toxicology-tabulated-summary": {
              "ctd_section": "2.6.7",
              "xml_element": "m2-6-7-toxicology-tabulated-summary",
              "content_model": "((leaf | node-extension)*)"
            }
          }
        },
        "m2-7-clinical-summary": {
          "ctd_section": "2.7",
          "xml_element": "m2-7-clinical-summary",
          "directory": "m2/27-clin-sum/",
          "required": false,
          "content_model": "(leaf*, m2-7-1-summary-of-biopharmaceutic-studies-and-associated-analytical-methods?, m2-7-2-summary-of-clinical-pharmacology-studies?, m2-7-3-summary-of-clinical-efficacy*, m2-7-4-summary-of-clinical-safety?, m2-7-5-literature-references?, m2-7-6-synopses-of-individual-studies?)",
          "children": {
            "m2-7-1-summary-of-biopharmaceutic-studies-and-associated-analytical-methods": {
              "ctd_section": "2.7.1",
              "xml_element": "m2-7-1-summary-of-biopharmaceutic-studies-and-associated-analytical-methods",
              "content_model": "((leaf | node-extension)*)"
            },
            "m2-7-2-summary-of-clinical-pharmacology-studies": {
              "ctd_section": "2.7.2",
              "xml_element": "m2-7-2-summary-of-clinical-pharmacology-studies",
              "content_model": "((leaf | node-extension)*)"
            },
            "m2-7-3-summary-of-clinical-efficacy": {
              "ctd_section": "2.7.3",
              "xml_element": "m2-7-3-summary-of-clinical-efficacy",
              "content_model": "((leaf | node-extension)*)",
              "attributes": {
                "indication": { "type": "CDATA", "required": true }
              },
              "notes": "Repeatable per indication"
            },
            "m2-7-4-summary-of-clinical-safety": {
              "ctd_section": "2.7.4",
              "xml_element": "m2-7-4-summary-of-clinical-safety",
              "content_model": "((leaf | node-extension)*)"
            },
            "m2-7-5-literature-references": {
              "ctd_section": "2.7.5",
              "xml_element": "m2-7-5-literature-references",
              "content_model": "((leaf | node-extension)*)"
            },
            "m2-7-6-synopses-of-individual-studies": {
              "ctd_section": "2.7.6",
              "xml_element": "m2-7-6-synopses-of-individual-studies",
              "content_model": "((leaf | node-extension)*)"
            }
          }
        }
      }
    },
    "m3-quality": {
      "ctd_section": "3",
      "xml_element": "m3-quality",
      "directory": "m3/",
      "required": false,
      "content_model": "(leaf*, m3-2-body-of-data?, m3-3-literature-references?)",
      "children": {
        "m3-2-body-of-data": {
          "ctd_section": "3.2",
