                  }
                },
                "m3-2-p-5-control-of-drug-product": {
                  "ctd_section": "3.2.P.5",
                  "content_model": "(leaf*, m3-2-p-5-1-specifications?, m3-2-p-5-2-analytical-procedures?, m3-2-p-5-3-validation-of-analytical-procedures?, m3-2-p-5-4-batch-analyses?, m3-2-p-5-5-characterisation-of-impurities?, m3-2-p-5-6-justification-of-specifications?)",
                  "children": {
