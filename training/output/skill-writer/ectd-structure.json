                  "children": {
                    "m3-2-s-2-1-manufacturer": { "ctd_section": "3.2.S.2.1", "content_model": "((leaf | node-extension)*)" },
                    "m3-2-s-2-2-description-of-manufacturing-process-and-process-controls": { "ctd_section": "3.2.S.2.2", "content_model": "((leaf | node-extension)*)" },
                    "m3-2-s-2-3-control-of-materials": { "ctd_section": "3.2.S.2.3", "content_model": "((leaf | node-extension)*)" },
                    "m3-2-s-2-4-controls-of-critical-steps-and-intermediates": { "ctd_section": "3.2.S.2.4", "content_model": "((leaf | node-extension)*)" },
