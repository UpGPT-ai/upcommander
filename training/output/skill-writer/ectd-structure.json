                  }
                },
                "m3-2-s-3-characterisation": {
                  "ctd_section": "3.2.S.3",
                  "xml_element": "m3-2-s-3-characterisation",
                  "content_model": "(leaf*, m3-2-s-3-1-elucidation-of-structure-and-other-characteristics?, m3-2-s-3-2-impurities?)",
                  "children": {
                    "m3-2-s-3-1-elucidation-of-structure-and-other-characteristics": { "ctd_section": "3.2.S.3.1", "content_model": "((leaf | node-extension)*)" },
                    "m3-2-s-3-2-impurities": { "ctd_section": "3.2.S.3.2", "content_model": "((leaf | node-extension)*)" }
                  }
                },
                "m3-2-s-4-control-of-drug-substance": {
                  "ctd_section": "3.2.S.4",
                  "xml_element": "m3-2-s-4-control-of-drug-substance",
                  "content_model": "(leaf*, m3-2-s-4-1-specification?, m3-2-s-4-2-analytical-procedures?, m3-2-s-4-3-validation-of-analytical-procedures?, m3-2-s-4-4-batch-analyses?, m3-2-s-4-5-justification-of-specification?)",
                  "children": {
                    "m3-2-s-4-1-specification": { "ctd_section": "3.2.S.4.1", "content_model": "((leaf | node-extension)*)" },
                    "m3-2-s-4-2-analytical-procedures": { "ctd_section": "3.2.S.4.2", "content_model": "((leaf | node-extension)*)" },
                    "m3-2-s-4-3-validation-of-analytical-procedures": { "ctd_section": "3.2.S.4.3", "content_model": "((leaf | node-extension)*)" },
